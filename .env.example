# === Database ===
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sharaco_db

# === Auth ===
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === Email ===
# Choisis ton provider : "smtp" (gratuit) ou "resend" (API)
EMAIL_PROVIDER=smtp

# --- SMTP (GRATUIT) ---
# Exemple Gmail : smtp.gmail.com / 587 / tonemail@gmail.com
# Exemple OVH   : ssl0.ovh.net / 465 / tonemail@tondomaine.com
# Exemple Infomaniak : smtp.infomaniak.com / 587 / tonemail@tondomaine.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tonemail@gmail.com
SMTP_PASSWORD=mot_de_passe_application
SMTP_FROM_NAME=Sharaco

# --- Resend (API, optionnel) ---
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_DOMAIN=onboarding@resend.dev

# === Redis (Celery) ===
REDIS_URL=redis://localhost:6379/0

# === Frontend ===
FRONTEND_URL=http://localhost:3000